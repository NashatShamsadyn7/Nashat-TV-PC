# ============================================================
# Nashat TV PC — Environment template
# ============================================================
# Copy this to `.env` and fill in your values.
# ============================================================

# ----- Firebase Web (renderer) -----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ----- Google OAuth (Desktop app Client ID from Google Cloud Console) -----
# Create at: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID → Desktop app
VITE_GOOGLE_CLIENT_ID=

# ----- TMDB (main process only) -----
TMDB_V3_KEY=
TMDB_V4_TOKEN=

# ----- Giphy (Watch Together chat GIF picker) -----
# Free key — https://developers.giphy.com/dashboard/ (no credit card).
# Tenor was discontinued in Jan 2026, so we use Giphy instead.
# Leave empty to disable GIFs (emoji + images still work).
VITE_GIPHY_API_KEY=

# ----- imgbb (Watch Together chat image upload) -----
# Free key — https://api.imgbb.com/ (no credit card).
# Used instead of Firebase Storage which now requires the Blaze plan.
VITE_IMGBB_API_KEY=
