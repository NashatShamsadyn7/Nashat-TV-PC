{
  "name": "nashat-tv-pc",
  "version": "1.3.0",
  "private": true,
  "description": "Nashat TV — Desktop edition. Live TV, Movies, Series & Actors.",
  "author": {
    "name": "Nashat Shamsadyne"
  },
  "license": "MIT",
  "main": "./out/main/index.js",
  "homepage": "./",
  "scripts": {
    "dev": "node scripts/run.mjs dev",
    "build": "node scripts/run.mjs build",
    "start": "node scripts/run.mjs preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "package:win": "node scripts/run.mjs build && electron-builder --win",
    "package:mac": "node scripts/run.mjs build && electron-builder --mac",
    "package:linux": "node scripts/run.mjs build && electron-builder --linux",
    "release:win": "node scripts/run.mjs build && electron-builder --win --publish always"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "firebase": "^11.1.0",
    "framer-motion": "^11.15.0",
    "fuse.js": "^7.3.0",
    "hls.js": "^1.5.18",
    "i18next": "^24.2.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
